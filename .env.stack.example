POSTGRES_DB=movee
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
JWT_SECRET_KEY=change_me_too

# Frontend domains allowed to call the backend.
CORS_ORIGINS=http://localhost:5173,http://localhost,https://www.nqmovee.site,https://nqmovee.site

# Local default: http://localhost:8001
# VPS example: https://ai.nqmovee.site or http://<server-ip>:8001
AI_PUBLIC_URL=http://localhost:8001

# Use cpu locally, or 0 with docker-compose.gpu.yml on NVIDIA servers.
DEVICE=cpu
STREAM_WIDTH=640
JPEG_QUALITY=75
